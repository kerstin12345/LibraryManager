<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="gui.OptionController"
            maxHeight="1080"
            maxWidth="1920"
            minHeight="540"
            minWidth="970"
            prefHeight="540"
            prefWidth="970">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Medienverwaltung" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="selectedMedium" text=""/>
            <Button text="Zurück zum Start" onAction="#goHome"/>
            <Button fx:id="closeButton" text="Beenden" onAction="#closing"/>
        </HBox>
    </top>
    <center>
        <GridPane hgap="15" vgap="10" style="-fx-padding: 20;">
            <Label text="Titel:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="title" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Jahr:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="published" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Kategorie:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="category" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Originalsprache:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="originalLanguage" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label text="Autor:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <TextField fx:id="autor" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            <Label text="ISBN:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <TextField fx:id="isbn" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

            <Label text="Regisseur:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
            <TextField fx:id="director" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

            <Label text="FSK:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
            <TextField fx:id="fsk" GridPane.rowIndex="7" GridPane.columnIndex="1"/>

            <Label text="Künstler:" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
            <TextField fx:id="artist" GridPane.rowIndex="8" GridPane.columnIndex="1"/>

            <Label text="Album:" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
            <TextField fx:id="album" GridPane.rowIndex="9" GridPane.columnIndex="1"/>
        </GridPane>
    </center>
    <left>
        <VBox spacing="10" style="-fx-padding: 10;">
            <Button fx:id="borrowMedium" text="Ausleihen"/>
            <Button fx:id="returnMedium" text="Zurückgeben"/>
            <Button fx:id="addMedium" text="Hinzufügen" onAction="#addMedium"/>
            <Button fx:id="removeMedium" text="Entfernen" onAction="#removeMedium"/>
        </VBox>
    </left>
    <bottom>
        <!--erst disable=false wenn alle benötigten parameter nicht mehr 0 sind-->
        <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10;">
            <Button text="Speichern" fx:id="saveButton" disable="true"/>
            <Button text="Suchen"/>
        </HBox>
    </bottom>
</BorderPane>
