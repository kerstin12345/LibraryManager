<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="gui.AllMediaController"
            maxHeight="1080"
            maxWidth="1920"
            minHeight="540"
            minWidth="970"
            prefHeight="540"
            prefWidth="970">
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Medienverwaltung" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Zurück zum Start" onAction="#goHome"/>
            <Button fx:id="closeButton" text="Beenden" onAction="#closing"/>
        </HBox>
    </top>
    <left>
        <VBox spacing="10" prefWidth="200">
            <Label text="Aktionen" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Button text="Sortieren"/>
            <Button text="Alle Medien anzeigen" onAction="#showAllMedia"/>
        </VBox>
    </left>
    <center>
        <VBox spacing="10" style="-fx-padding: 15;">

            <Label text="Medienübersicht"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <ScrollPane fitToWidth="true" fitToHeight="true">
                <content>
                    <TextArea fx:id="mediaShowed" editable="false"
                              wrapText="true"
                              style="-fx-font-family: Consolas;
                                     -fx-font-size: 14px;"/>
                </content>
            </ScrollPane>

        </VBox>
    </center>
</BorderPane>
